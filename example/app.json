{
  "expo": {
    "name": "React Native Paper Example - Harshal",
    "description": "Your custom build",
    "slug": "react-native-paper-example-harshal",
    "privacy": "public",
    "version": "1.0.0",
    "orientation": "default",
    "primaryColor": "#6200EE",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/paper-icon.png",
    "newArchEnabled": true,
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "owner": "harshald",
    "ios": {
      "bundleIdentifier": "com.harshald.paperexample"
    },
    "android": {
      "package": "com.harshald.paperexample",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon.png",
        "backgroundColor": "#6200EE"
      }
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#6200EE",
      "resizeMode": "cover"
    },
    "runtimeVersion": "exposdk:52.0.0",
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "7775f939-c899-435e-9733-6f717715a3a8"
      }
    }
  }
}
